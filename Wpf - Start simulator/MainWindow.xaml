<Window x:Class="Wpf___Start_simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf___Start_simulator"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="32"/>
            <RowDefinition Height="Auto" MinHeight="56.04"/>
            <RowDefinition Height="Auto" MinHeight="83"/>
        </Grid.RowDefinitions>
        <Button x:Name="Start" Content="Start" HorizontalAlignment="Left" Margin="241,0,0,0" Grid.Row="3" VerticalAlignment="Center" Width="100" Height="50" FontSize="24" Click="Start_Click"/>
        <Border BorderBrush="Black" BorderThickness="1" Margin="10,10,10,10" Background="#FF4A4A4A" Grid.Row="0" CornerRadius="50,50,50,50">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal"   >
                <Ellipse x:Name="Light1"  Margin="5"  Height="100" Width="100"   Fill="#FF620202" />
                <Ellipse x:Name="Light2"  Margin="5"  Fill="#FF620202" Height="100" Width="100"/>
                <Ellipse x:Name="Light3"  Margin="5"  Fill="#FF620202" Height="100" Width="100"/>
                <Ellipse x:Name="Light4"  Margin="5"  Fill="#FF620202" Height="100" Width="100"/>
                <Ellipse x:Name="Light5"  Margin="5"  Fill="#FF620202" Height="100" Width="100"/>
            </StackPanel>
        </Border>
        <Button x:Name="GoButton" Content="Go" HorizontalAlignment="Left" Margin="459,0,0,0" Grid.Row="3" VerticalAlignment="Center" Width="100" Height="50" FontSize="24" Click="GoButton_Click"/>
        <TextBlock x:Name="TimerLabel" HorizontalAlignment="Left" Grid.Row="2" TextWrapping="Wrap" Text="--- . --- s" VerticalAlignment="Top" Width="218" Height="50" FontSize="24" Foreground="White" Margin="341,6,0,0"/>

    </Grid>
</Window>
